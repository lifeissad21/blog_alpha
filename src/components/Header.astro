---
import ThemeSwitch from "@/components/ThemeSwitch.astro";

interface Props {
  section?: string;
}

const { section } = Astro.props;

const getSectionDisplay = (section?: string) => {
  if (!section) return 'MyBlog';
  
  switch (section) {
    case 'home':
      return 'MyBlog';
    case 'blog':
      return 'blog';
    case 'now':
      return 'now';
    case 'tag':
      return 'tags';
    default:
      return section;
  }
};
---

<header class="max-w-2xl mx-auto px-6 w-full">
  <div class="py-8 flex items-center justify-between">
    <div class="flex items-center gap-4">
      <a href="/blog_alpha/" class="text-xl font-medium dark:text-zinc-200">MyBlog</a>
      {section && section !== 'home' && (
        <>
          <span class="text-slate-400 dark:text-zinc-600">/</span>
          <span class="text-sm text-slate-600 dark:text-zinc-400">{getSectionDisplay(section)}</span>
        </>
      )}
    </div>
    <nav class="flex items-center gap-6">
      <a href="/blog_alpha/blog" class="text-sm hover:underline dark:text-zinc-400 dark:hover:text-zinc-200">Blog</a>
      <a href="/blog_alpha/now" class="text-sm hover:underline dark:text-zinc-400 dark:hover:text-zinc-200">Now</a>
      <ThemeSwitch />
    </nav>
  </div>
</header>
