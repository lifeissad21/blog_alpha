---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Server Error">
  <div class="max-w-2xl mx-auto px-6 w-full">
    <div class="py-24 flex flex-col items-center justify-center text-center">
      <div class="mb-8">
        <h1 class="text-6xl font-black mb-4 dark:text-zinc-200">500</h1>
        <p class="text-2xl font-semibold text-slate-900 dark:text-zinc-300 mb-2">Server Error</p>
        <p class="text-slate-600 dark:text-zinc-500 max-w-md">
          Something went wrong on our end. Please try again later.
        </p>
      </div>
      
      <div class="flex gap-4">
        <a href="/blog_alpha/" class="px-6 py-2 bg-slate-900 dark:bg-zinc-700 text-white dark:text-zinc-100 rounded hover:bg-slate-800 dark:hover:bg-zinc-600 transition-colors">
          Back to Home
        </a>
        <a href="/blog_alpha/blog" class="px-6 py-2 border border-slate-300 dark:border-zinc-600 text-slate-900 dark:text-zinc-300 rounded hover:bg-slate-50 dark:hover:bg-zinc-800 transition-colors">
          View Blog
        </a>
      </div>
    </div>
  </div>
</MainLayout>
