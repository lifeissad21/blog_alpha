---
import MainLayout from '../../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';

// Get all blog posts from the content collection
const allPosts = await getCollection('blog');

// Sort posts by date (newest first)
const sortedPosts = allPosts.sort((a, b) => {
  return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
});

// Format date helper
function formatDate(dateString: string): string {
  return new Date(dateString).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });
}

// Extract year and month for writing section
function getYearMonth(dateString: string): string {
  const date = new Date(dateString);
  const year = date.getFullYear();
  const month = String(date.getMonth() + 1).padStart(2, '0');
  const day = String(date.getDate()).padStart(2, '0');
  return `${year} · ${month} · ${day}`;
}
---

<MainLayout title="Blog">
  <div class="max-w-2xl mx-auto px-6 w-full">
    <div class="py-12 space-y-12">
      {sortedPosts.length === 0 ? (
        <p class="text-slate-600 dark:text-zinc-500">No blog posts yet. Check back soon!</p>
      ) : (
        <>
          <!-- Latest -->
          <section>
            <h2 class="text-sm font-medium text-slate-600 dark:text-zinc-500 mb-6">Latest</h2>
            <div class="space-y-6">
              {sortedPosts.slice(0, 1).map((post) => (
                <article>
                  <a href={`/blog_alpha/blog/${post.id}`} class="group">
                    <h3 class="text-lg font-semibold group-hover:underline mb-2 dark:text-zinc-200">
                      {post.data.title}
                    </h3>
                  </a>
                  <div class="flex items-center gap-2 text-sm text-slate-600 dark:text-zinc-500 mb-2">
                    <time>{formatDate(post.data.date)}</time>
                    <span>·</span>
                    <span>3 minute read</span>
                    {post.data.tags && post.data.tags.length > 0 && (
                      <>
                        <span>·</span>
                        <div class="flex gap-1">
                          {post.data.tags.map((tag: string) => (
                            <a href={`/blog_alpha/tags/${tag}`} class="hover:underline">#{tag}</a>
                          ))}
                        </div>
                      </>
                    )}
                  </div>
                  {post.data.excerpt && (
                    <p class="text-slate-700 dark:text-zinc-400">{post.data.excerpt}</p>
                  )}
                </article>
              ))}
            </div>
          </section>

          <!-- All Posts -->
          {sortedPosts.length > 1 && (
            <section>
              <h2 class="text-sm font-medium text-slate-600 dark:text-zinc-500 mb-6">Writing</h2>
              <div class="space-y-2">
                {sortedPosts.map((post) => (
                  <div class="flex gap-4">
                    <span class="text-sm text-slate-600 dark:text-zinc-500 w-24 flex-shrink-0">{getYearMonth(post.data.date)}</span>
                    <a href={`/blog_alpha/blog/${post.id}`} class="text-sm hover:underline dark:text-zinc-400 dark:hover:text-zinc-200">
                      {post.data.title}
                    </a>
                  </div>
                ))}
              </div>
            </section>
          )}
        </>
      )}
    </div>
  </div>
</MainLayout>
